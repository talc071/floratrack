# Server
PORT=3000
NODE_ENV=development

# CORS (React dev server)
CORS_ORIGIN=http://localhost:3001

# MySQL Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=floratrack
DB_USER=root
DB_PASSWORD=
DB_LOGGING=false
DB_SYNC=false

# AI Providers - never expose to frontend
PLANT_ID_API_KEY=your_plant_id_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Set to true on first run to auto-sync schema (prefer migrations/seed for production)
# DB_SYNC=true
